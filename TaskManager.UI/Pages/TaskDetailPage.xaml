<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TaskManager.UI.TaskDetailPage"
             Title="Деталі завдання">

    <ScrollView>
        <StackLayout Padding="16" Spacing="12">

            <!-- Статус бейдж -->
            <Frame x:Name="StatusFrame" CornerRadius="8" Padding="12" HasShadow="False">
                <Label x:Name="StatusLabel" FontSize="16" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center"/>
            </Frame>

            <!-- Назва -->
            <Label x:Name="TitleLabel" FontSize="22" FontAttributes="Bold"
                   TextColor="#2C3E50" HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>

            <!-- Деталі -->
            <Frame BackgroundColor="White" CornerRadius="10" Padding="16" HasShadow="True">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*" RowSpacing="12">

                    <Label Grid.Row="0" Grid.Column="0" Text="Пріоритет:"
                           FontSize="14" TextColor="#7F8C8D" FontAttributes="Bold"/>
                    <Label Grid.Row="0" Grid.Column="1" x:Name="PriorityLabel"
                           FontSize="14" TextColor="#2C3E50"/>

                    <Label Grid.Row="1" Grid.Column="0" Text="Дедлайн:"
                           FontSize="14" TextColor="#7F8C8D" FontAttributes="Bold"/>
                    <Label Grid.Row="1" Grid.Column="1" x:Name="DueDateLabel"
                           FontSize="14" TextColor="#2C3E50"/>

                    <Label Grid.Row="2" Grid.Column="0" Text="Прострочено:"
                           FontSize="14" TextColor="#7F8C8D" FontAttributes="Bold"/>
                    <Label Grid.Row="2" Grid.Column="1" x:Name="OverdueLabel"
                           FontSize="14"/>

                    <Label Grid.Row="3" Grid.Column="0" Text="Виконано:"
                           FontSize="14" TextColor="#7F8C8D" FontAttributes="Bold"/>
                    <Label Grid.Row="3" Grid.Column="1" x:Name="CompletedLabel"
                           FontSize="14"/>
                </Grid>
            </Frame>

            <!-- Опис -->
            <Label Text="Опис" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50"/>
            <Frame BackgroundColor="White" CornerRadius="10" Padding="16" HasShadow="True">
                <Label x:Name="DescriptionLabel" FontSize="14" TextColor="#555"/>
            </Frame>

        </StackLayout>
    </ScrollView>
</ContentPage>

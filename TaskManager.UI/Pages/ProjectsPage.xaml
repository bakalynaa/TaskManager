<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TaskManager.UI.ProjectsPage"
             Title="Проєкти">

    <ContentPage.Resources>
        <Style x:Key="CardFrame" TargetType="Frame">
            <Setter Property="BackgroundColor" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="12,6"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="HasShadow" Value="True"/>
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Заголовок -->
        <StackLayout Grid.Row="0" BackgroundColor="#2C3E50" Padding="16">
            <Label Text="Task Manager"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White"/>
            <Label Text="Оберіть проєкт для перегляду"
                   FontSize="13" TextColor="#BDC3C7"/>
        </StackLayout>

        <!-- Список проєктів -->
        <CollectionView Grid.Row="1"
                        x:Name="ProjectsCollection"
                        SelectionMode="Single"
                        SelectionChanged="OnProjectSelected"
                        Margin="0,8">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource CardFrame}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Name}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#2C3E50"/>

                            <Label Grid.Row="0" Grid.Column="1"
                                   Text="{Binding Type}"
                                   FontSize="12" TextColor="White"
                                   BackgroundColor="#3498DB"
                                   Padding="6,2" VerticalOptions="Start"/>

                            <Label Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{Binding Description}"
                                   FontSize="13" TextColor="#7F8C8D"
                                   Margin="0,4,0,0"/>

                            <ProgressBar Grid.Row="2" Grid.ColumnSpan="2"
                                         Progress="{Binding ProgressFraction}"
                                         ProgressColor="#27AE60"
                                         Margin="0,8,0,0"/>

                            <Label Grid.Row="2" Grid.Column="1"
                                   Text="{Binding ProgressText}"
                                   FontSize="11" TextColor="#27AE60"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>

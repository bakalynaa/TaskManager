<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TaskManager.UI.ProjectDetailPage"
             Title="Деталі проєкту">

    <ScrollView>
        <StackLayout Spacing="0">

            <!-- Інфо про проєкт -->
            <Frame BackgroundColor="#2C3E50" CornerRadius="0" Padding="16" HasShadow="False">
                <StackLayout>
                    <Label x:Name="ProjectNameLabel"
                           FontSize="20" FontAttributes="Bold" TextColor="White"/>
                    <Label x:Name="ProjectTypeLabel"
                           FontSize="13" TextColor="#BDC3C7" Margin="0,2,0,0"/>
                    <Label x:Name="ProjectDescLabel"
                           FontSize="13" TextColor="#ECF0F1" Margin="0,6,0,0"/>
                    <ProgressBar x:Name="ProjectProgress"
                                 ProgressColor="#27AE60" Margin="0,10,0,0"/>
                    <Label x:Name="ProjectProgressLabel"
                           FontSize="12" TextColor="#27AE60"/>
                </StackLayout>
            </Frame>

            <!-- Заголовок списку завдань -->
            <Label Text="Завдання" FontSize="16" FontAttributes="Bold"
                   TextColor="#2C3E50" Margin="16,16,16,8"/>

            <!-- Список завдань -->
            <CollectionView x:Name="TasksCollection"
                            SelectionMode="Single"
                            SelectionChanged="OnTaskSelected"
                            HeightRequest="600">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" CornerRadius="8"
                               Margin="12,4" Padding="14" HasShadow="True">
                            <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,Auto">

                                <!-- Статус -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding StatusIcon}"
                                       FontSize="18" VerticalOptions="Center"
                                       Margin="0,0,10,0"/>

                                <!-- Назва -->
                                <Label Grid.Row="0" Grid.Column="1"
                                       Text="{Binding Title}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="#2C3E50" VerticalOptions="Center"/>

                                <!-- Пріоритет -->
                                <Label Grid.Row="0" Grid.Column="2"
                                       Text="{Binding Priority}"
                                       FontSize="11" TextColor="White"
                                       BackgroundColor="{Binding PriorityColor}"
                                       Padding="6,2" VerticalOptions="Start"/>

                                <!-- Дедлайн -->
                                <Label Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                       Text="{Binding DueDateText}"
                                       FontSize="12" TextColor="#95A5A6"
                                       Margin="0,4,0,0"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </StackLayout>
    </ScrollView>
</ContentPage>

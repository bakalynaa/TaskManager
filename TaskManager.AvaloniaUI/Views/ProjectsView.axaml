<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TaskManager.AvaloniaUI.ViewModels;assembly=TaskManager.AvaloniaUI"
             xmlns:dto="clr-namespace:TaskManager.Services.DTOs;assembly=TaskManager.Services"
             x:Class="TaskManager.AvaloniaUI.Views.ProjectsView"
             x:DataType="vm:ProjectsViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Панель пошуку і сортування -->
        <Border Grid.Row="0" Background="#34495E" Padding="12,8">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Grid.Column="0" Text="{Binding SearchText}" Watermark="🔍 Пошук проєктів..." Margin="0,0,8,0"/>
                <ComboBox Grid.Column="1" ItemsSource="{Binding SortLabels}"
                          SelectedIndex="0" Width="160" Margin="0,0,8,0"
                          SelectionChanged="OnSortChanged"/>
                <Button Grid.Column="2" Content="+ Додати" Command="{Binding AddProjectCommand}"
                        Background="#27AE60" Foreground="White" Padding="12,6"/>
            </Grid>
        </Border>

        <!-- Індикатор завантаження -->
        <ProgressBar Grid.Row="1" IsIndeterminate="True"
                     IsVisible="{Binding IsBusy}" Height="4"/>

        <!-- Список проєктів -->
        <ScrollViewer Grid.Row="2" Padding="12">
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="dto:ProjectListDto">
                        <Border Background="White" CornerRadius="8" Margin="0,6" Padding="16">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto">

                                <TextBlock Grid.Row="0" Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>

                                <Border Grid.Row="0" Grid.Column="1"
                                        Background="#3498DB" CornerRadius="4" Padding="8,3" Margin="8,0">
                                    <TextBlock Text="{Binding Type}" Foreground="White" FontSize="12"/>
                                </Border>

                                <Button Grid.Row="0" Grid.Column="2"
                                        Content="🗑"
                                        Command="{Binding $parent[UserControl].((vm:ProjectsViewModel)DataContext).DeleteProjectCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="#E74C3C"
                                        Padding="4" ToolTip.Tip="Видалити проєкт"/>

                                <TextBlock Grid.Row="1" Grid.ColumnSpan="3"
                                           Text="{Binding Description}"
                                           FontSize="13" Foreground="#7F8C8D"
                                           Margin="0,6,0,0" TextWrapping="Wrap"/>

                                <Grid Grid.Row="2" Grid.ColumnSpan="3" ColumnDefinitions="*,Auto" Margin="0,10,0,0">
                                    <ProgressBar Grid.Column="0" Value="{Binding Progress}"
                                                 Minimum="0" Maximum="100" Height="6" Foreground="#27AE60"/>
                                    <TextBlock Grid.Column="1" Text="{Binding ProgressText}"
                                               FontSize="11" Foreground="#27AE60" Margin="8,0,0,0"/>
                                </Grid>

                                <!-- Кнопка переходу -->
                                <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Grid.ColumnSpan="3"
                                        Command="{Binding $parent[UserControl].((vm:ProjectsViewModel)DataContext).SelectProjectCommand}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Opacity="0"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TaskManager.AvaloniaUI.ViewModels;assembly=TaskManager.AvaloniaUI"
             xmlns:dto="clr-namespace:TaskManager.Services.DTOs;assembly=TaskManager.Services"
             x:Class="TaskManager.AvaloniaUI.Views.ProjectsView"
             x:DataType="vm:ProjectsViewModel">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#34495E" Padding="16,10">
            <TextBlock Text="Оберіть проєкт для перегляду" Foreground="#BDC3C7" FontSize="13"/>
        </Border>
        <ScrollViewer Grid.Row="1" Padding="12">
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="dto:ProjectListDto">
                        <Button Command="{Binding $parent[UserControl].((vm:ProjectsViewModel)DataContext).SelectProjectCommand}"
                                CommandParameter="{Binding}"
                                Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Margin="0,6" Padding="0">
                            <Border Background="White" CornerRadius="8" Padding="16">
                                <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                                    <Border Grid.Row="0" Grid.Column="1" Background="#3498DB" CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="{Binding Type}" Foreground="White" FontSize="12"/>
                                    </Border>
                                    <TextBlock Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Description}" FontSize="13" Foreground="#7F8C8D" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
                                        <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100" Height="6" Foreground="#27AE60"/>
                                        <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="#27AE60" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
